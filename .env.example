# ---------- Gateway ----------
GATEWAY_PORT=8080
# Comma-separated API keys allowed to call the gateway (use tools/gen_apikey.py)
GATEWAY_API_KEYS=
# Optional: map api keys to allowed streams/projects (JSON). Example:
# {"<apikey1>":{"streams":["MyStreamA","MyStreamB"]},"<apikey2>":{"streams":["*"]}}
GATEWAY_KEY_POLICY_JSON={}
# Forward target (core service)
CORE_BASE_URL=http://core:8000

# ---------- Core ----------
CORE_PORT=8000
COVERITY_BASE_URL=
# Preferred: use a dedicated read-only API user/token. Put token in a secret manager in real deployments.
COVERITY_AUTH_TOKEN=
# TLS verification: KEEP ON by default.
COVERITY_TLS_VERIFY=true
# Optional CA bundle path mounted into the container, if needed:
COVERITY_CA_BUNDLE=

# Hard safety limits
MAX_LIMIT=200
MAX_LOOKBACK_DAYS=365
HTTP_TIMEOUT_SECONDS=10

# Logging
LOG_LEVEL=INFO
