# ---------- Gateway ----------
GATEWAY_PORT=8080
# Comma-separated API keys allowed to call the gateway (use tools/gen_apikey.py)
GATEWAY_API_KEYS=
# Optional: map api keys to allowed streams/projects (JSON). Example:
# {"<apikey1>":{"streams":["MyStreamA","MyStreamB"]},"<apikey2>":{"streams":["*"]}}
GATEWAY_KEY_POLICY_JSON={}
# Forward target (core service)
CORE_BASE_URL=http://core:8000

# ---------- Core ----------
CORE_PORT=8000
COVERITY_BASE_URL=
COVERITY_USERNAME=
COVERITY_PASSWORD=
# TLS verification: KEEP ON by default.
COVERITY_TLS_VERIFY=true
# Optional CA bundle path mounted into the container, if needed:
COVERITY_CA_BUNDLE=

# Hard safety limits
MAX_LIMIT=200
MAX_LOOKBACK_DAYS=365
HTTP_TIMEOUT_SECONDS=10

# Logging
LOG_LEVEL=INFO

# ---------- Agent ----------
AGENT_PORT=8090
AGENT_LOG_LEVEL=INFO
GATEWAY_BASE_URL=http://gateway:8080
# This should be one of the values configured in GATEWAY_API_KEYS
AGENT_GATEWAY_API_KEY=
LLM_BASE_URL=
LLM_MODEL=
LLM_API_KEY=
LLM_TIMEOUT_SECONDS=60
LLM_MAX_TOOL_ROUND_TRIPS=6
LLM_TEMPERATURE=0
